<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>WebGIS ZNT Waru – Kecamatan Waru, Sidoarjo</title>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --white:    #ffffff;
      --bg:       #f5f6fa;
      --border:   #e2e5ec;
      --border2:  #d0d5e1;
      --text:     #1a202c;
      --muted:    #718096;
      --blue:     #2563eb;
      --blue-light:#eff6ff;
      --red:      #ef4444;
      --red-light:#fef2f2;
      --green:    #16a34a;
      --green-light:#f0fdf4;
      --orange:   #ea580c;
      --orange-light:#fff7ed;
      --purple:   #7c3aed;
      --teal:     #0d9488;

      --rendah:   #3b82f6;
      --sedang:   #22c55e;
      --tinggi:   #ef4444;

      --nav-h:    56px;
      --panel-w:  272px;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      height: 100vh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      font-size: 13px;
    }

    /* ── NAVBAR ── */
    nav {
      height: var(--nav-h);
      background: var(--white);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 20px;
      gap: 16px;
      flex-shrink: 0;
      z-index: 10000;
      box-shadow: 0 1px 3px rgba(0,0,0,.06);
    }

    .nav-brand {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .nav-logo {
      width: 34px; height: 34px;
      background: linear-gradient(135deg, #f97316, #ef4444);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px;
    }
    .nav-title { font-size: 14px; font-weight: 700; color: var(--text); line-height: 1.2; }
    .nav-subtitle { font-size: 11px; color: var(--muted); }

    .nav-chips { display: flex; gap: 6px; margin-left: 4px; }
    .chip {
      padding: 3px 10px;
      border-radius: 99px;
      font-size: 11px;
      font-weight: 600;
      border: 1px solid transparent;
    }
    .chip-blue  { background: var(--blue-light);   color: var(--blue);   border-color: #bfdbfe; }
    .chip-green { background: var(--green-light);  color: var(--green);  border-color: #bbf7d0; }
    .chip-red   { background: var(--red-light);    color: var(--red);    border-color: #fecaca; }

    .nav-spacer { flex: 1; }

    .nav-links { display: flex; gap: 2px; }
    .nav-link {
      padding: 6px 14px;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 500;
      color: var(--muted);
      cursor: pointer;
      background: transparent;
      border: none;
      font-family: inherit;
      transition: all .15s;
    }
    .nav-link:hover { background: var(--bg); color: var(--text); }
    .nav-link.active {
      background: var(--blue);
      color: #fff;
      font-weight: 600;
    }

    /* ── LAYOUT ── */
    .app-body {
      flex: 1;
      display: flex;
      overflow: hidden;
      position: relative;
    }

    /* ── SIDE PANEL ── */
    .panel {
      width: var(--panel-w);
      background: var(--white);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      flex-shrink: 0;
      z-index: 500;
    }

    /* panel tab bar */
    .panel-tabs {
      display: flex;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .ptab {
      flex: 1;
      padding: 10px 0;
      text-align: center;
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: all .15s;
    }
    .ptab.active { color: var(--blue); border-bottom-color: var(--blue); }

    .panel-body {
      flex: 1;
      overflow-y: auto;
      padding: 14px;
    }
    .panel-body::-webkit-scrollbar { width: 4px; }
    .panel-body::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 4px; }

    .panel-section { margin-bottom: 18px; }
    .section-label {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--muted);
      margin-bottom: 8px;
    }

    /* layer row */
    .layer-item {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 7px 9px;
      border-radius: 7px;
      margin-bottom: 2px;
      cursor: pointer;
      transition: background .12s;
    }
    .layer-item:hover { background: var(--bg); }
    .layer-item input[type=checkbox] {
      accent-color: var(--blue);
      width: 14px; height: 14px;
      cursor: pointer;
      flex-shrink: 0;
    }
    .layer-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .layer-name { flex: 1; font-size: 12px; font-weight: 500; }
    .layer-eye {
      color: var(--muted);
      font-size: 13px;
      cursor: pointer;
      opacity: .5;
    }
    .layer-eye:hover { opacity: 1; }

    /* slider */
    .slider-section { padding: 4px 2px; }
    .slider-row { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
    .slider-label { font-size: 11px; color: var(--muted); flex: 1; }
    .slider-val { font-size: 11px; font-weight: 600; color: var(--blue); min-width: 34px; text-align: right; }
    input[type=range] {
      width: 100%;
      accent-color: var(--blue);
      margin-top: 2px;
    }

    /* filter */
    select, input[type=text] {
      width: 100%;
      border: 1px solid var(--border2);
      border-radius: 7px;
      padding: 7px 10px;
      font-size: 12px;
      color: var(--text);
      background: var(--white);
      font-family: inherit;
      outline: none;
      transition: border-color .15s;
      margin-bottom: 8px;
    }
    select:focus, input[type=text]:focus { border-color: var(--blue); }

    .btn-reset {
      width: 100%;
      padding: 8px;
      border: 1px solid var(--border2);
      border-radius: 7px;
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      background: var(--white);
      cursor: pointer;
      font-family: inherit;
      transition: all .15s;
    }
    .btn-reset:hover { border-color: var(--blue); color: var(--blue); background: var(--blue-light); }

    /* legend */
    .legend-row {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      color: var(--text);
      padding: 3px 0;
    }
    .leg-swatch { width: 28px; height: 12px; border-radius: 3px; flex-shrink: 0; }
    .leg-icon { font-size: 14px; }

    /* info tip at bottom of panel */
    .panel-tip {
      padding: 10px 14px;
      border-top: 1px solid var(--border);
      font-size: 10px;
      color: var(--muted);
      line-height: 1.5;
      flex-shrink: 0;
    }

    /* ── MAP ── */
    #map {
      flex: 1;
      z-index: 1;
    }

    /* coordinates bar */
    .coords-bar {
      position: absolute;
      bottom: 0; left: var(--panel-w);
      right: 0;
      height: 22px;
      background: rgba(255,255,255,.92);
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 12px;
      gap: 16px;
      font-size: 10px;
      color: var(--muted);
      z-index: 900;
      font-family: monospace;
    }
    .coords-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); }

    /* custom popup */
    .leaflet-popup-content-wrapper {
      border-radius: 10px !important;
      box-shadow: 0 8px 30px rgba(0,0,0,.15) !important;
      border: 1px solid var(--border) !important;
      padding: 0 !important;
    }
    .leaflet-popup-content { margin: 0 !important; }
    .leaflet-popup-tip-container { display: none; }

    .popup-box { padding: 14px 16px; min-width: 210px; }
    .popup-head {
      font-size: 13px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 3px;
    }
    .popup-badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 99px;
      font-size: 10px;
      font-weight: 700;
      margin-bottom: 10px;
    }
    .popup-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    .popup-kv { display: flex; flex-direction: column; gap: 1px; }
    .popup-k { font-size: 10px; color: var(--muted); }
    .popup-v { font-size: 12px; font-weight: 600; }
    .popup-divider { border: none; border-top: 1px solid var(--border); margin: 8px 0 6px; }
    .popup-note { font-size: 10px; color: var(--muted); }

    /* ── DASHBOARD VIEW ── */
    #dash-view {
      flex: 1;
      overflow-y: auto;
      background: var(--bg);
      padding: 24px;
      display: none;
    }
    #dash-view.show { display: block; }

    .dash-header { margin-bottom: 20px; }
    .dash-header h2 { font-size: 18px; font-weight: 700; }
    .dash-header p { font-size: 12px; color: var(--muted); margin-top: 2px; }

    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-bottom: 18px;
    }
    .kpi {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px 16px;
      position: relative;
      overflow: hidden;
    }
    .kpi-bar {
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 4px;
      border-radius: 10px 0 0 10px;
    }
    .kpi-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .7px; margin-bottom: 6px; }
    .kpi-val { font-size: 22px; font-weight: 700; }
    .kpi-sub { font-size: 10px; color: var(--muted); margin-top: 3px; }

    .card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px;
      margin-bottom: 14px;
    }
    .card-title { font-size: 13px; font-weight: 700; margin-bottom: 14px; color: var(--text); }

    /* bar chart */
    .bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 7px; }
    .bar-label { font-size: 11px; width: 120px; flex-shrink: 0; color: var(--text); }
    .bar-track { flex: 1; background: var(--bg); border-radius: 4px; height: 20px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 4px; display: flex; align-items: center; padding-left: 8px; transition: width .5s; }
    .bar-text { font-size: 10px; font-weight: 700; color: #fff; white-space: nowrap; }

    /* histogram */
    .hist-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
    .hist-label { font-size: 10px; color: var(--muted); width: 84px; flex-shrink: 0; }
    .hist-track { flex: 1; background: var(--bg); height: 18px; border-radius: 4px; overflow: hidden; }
    .hist-fill { height: 100%; border-radius: 4px; display: flex; align-items: center; padding-left: 6px; }
    .hist-count { font-size: 10px; font-weight: 700; color: #fff; }

    /* scatter SVG */
    .scatter-svg { width: 100%; height: 220px; }

    /* box plot */
    .box-wrap { display: flex; gap: 24px; justify-content: center; padding: 8px 0; }

    /* table */
    table { width: 100%; border-collapse: collapse; font-size: 11px; }
    th {
      background: var(--bg);
      padding: 8px 10px;
      text-align: left;
      font-size: 10px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .6px;
      border-bottom: 1px solid var(--border);
      font-weight: 600;
    }
    td { padding: 8px 10px; border-bottom: 1px solid var(--border); }
    tr:hover td { background: var(--bg); }
    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 99px;
      font-size: 10px;
      font-weight: 600;
    }

    .btn-export {
      padding: 7px 16px;
      background: var(--blue);
      color: #fff;
      border: none;
      border-radius: 7px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
    }
    .btn-export:hover { background: #1d4ed8; }

    /* ── STORY VIEW ── */
    #story-view {
      flex: 1;
      overflow-y: auto;
      background: var(--white);
      display: none;
    }
    #story-view.show { display: block; }

    .story-hero {
      background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%);
      padding: 60px 48px;
      text-align: center;
      color: #fff;
    }
    .story-hero h1 { font-size: 32px; font-weight: 700; margin-bottom: 10px; }
    .story-hero p { font-size: 14px; opacity: .8; max-width: 540px; margin: 0 auto; }

    .story-chaps { max-width: 960px; margin: 0 auto; }

    .chap {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-bottom: 1px solid var(--border);
      min-height: 340px;
    }
    .chap.rev { direction: rtl; }
    .chap.rev > * { direction: ltr; }

    .chap-text {
      padding: 44px 40px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 12px;
    }
    .chap-num { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: var(--blue); }
    .chap-title { font-size: 22px; font-weight: 700; color: var(--text); }
    .chap-desc { font-size: 13px; color: var(--muted); line-height: 1.75; }

    .chap-vis {
      background: var(--bg);
      border-left: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 28px;
    }
    .chap.rev .chap-vis { border-left: none; border-right: 1px solid var(--border); }

    /* story infographic blocks */
    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; width: 100%; }
    .info-box {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 14px;
      text-align: center;
    }
    .info-val { font-size: 22px; font-weight: 700; }
    .info-lbl { font-size: 10px; color: var(--muted); margin-top: 2px; }

    .factor-list { width: 100%; display: flex; flex-direction: column; gap: 8px; }
    .factor-item {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 7px;
      padding: 9px 12px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .factor-name { font-size: 11px; font-weight: 500; width: 110px; flex-shrink: 0; }
    .fbar-wrap { flex: 1; background: var(--bg); height: 6px; border-radius: 3px; }
    .fbar-fill { height: 100%; border-radius: 3px; }
    .factor-pct { font-size: 11px; font-weight: 600; color: var(--text); min-width: 30px; text-align: right; }

    /* team */
    .team-section {
      border-top: 1px solid var(--border);
      padding: 48px 40px;
      text-align: center;
      background: var(--bg);
    }
    .team-section h2 { font-size: 18px; font-weight: 700; margin-bottom: 4px; }
    .team-section > p { font-size: 12px; color: var(--muted); margin-bottom: 28px; }
    .team-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; max-width: 840px; margin: 0 auto; }
    .team-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px 12px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 9px;
    }
    .team-avatar {
      width: 60px; height: 60px;
      border-radius: 50%;
      background: linear-gradient(135deg, #2563eb, #7c3aed);
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; font-weight: 700; color: #fff;
      overflow: hidden;
    }
    .team-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .team-name { font-size: 12px; font-weight: 600; text-align: center; line-height: 1.4; }
    .team-role { font-size: 10px; color: var(--muted); }

    /* ── BERANDA ─────────────────────────────────────── */
    .brd-hero {
      position: relative;
      min-height: 340px;
      background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 40%, #0f172a 100%);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 48px 48px 32px;
    }
    .brd-hero-bg {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 60% 80% at 80% 50%, rgba(37,99,235,.18) 0%, transparent 70%),
        radial-gradient(ellipse 40% 60% at 10% 30%, rgba(124,58,237,.15) 0%, transparent 60%),
        radial-gradient(ellipse 30% 40% at 50% 80%, rgba(13,148,136,.12) 0%, transparent 60%);
      pointer-events: none;
    }
    .brd-hero-bg::before {
      content: '';
      position: absolute; inset: 0;
      background-image: radial-gradient(circle, rgba(255,255,255,.04) 1px, transparent 1px);
      background-size: 28px 28px;
    }
    .brd-hero-content { position: relative; max-width: 680px; }
    .brd-badge {
      display: inline-block;
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.12);
      color: rgba(255,255,255,.7);
      font-size: 11px; font-weight: 500;
      padding: 4px 12px; border-radius: 99px;
      margin-bottom: 18px; letter-spacing: .3px;
    }
    .brd-title {
      font-size: 44px; font-weight: 800; line-height: 1.1;
      color: #fff; margin-bottom: 14px;
    }
    .brd-title span {
      background: linear-gradient(90deg, #60a5fa, #a78bfa, #34d399);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .brd-sub { font-size: 14px; color: rgba(255,255,255,.6); line-height: 1.8; max-width: 520px; margin-bottom: 28px; }
    .brd-sub strong { color: rgba(255,255,255,.9); }
    .brd-cta-row { display: flex; gap: 10px; flex-wrap: wrap; }
    .brd-cta {
      display: flex; align-items: center; gap: 7px;
      padding: 10px 20px; border-radius: 8px; border: none;
      font-size: 13px; font-weight: 600; cursor: pointer;
      font-family: inherit; transition: all .2s; white-space: nowrap;
    }
    .brd-cta-primary { background: #2563eb; color: #fff; }
    .brd-cta-primary:hover { background: #1d4ed8; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(37,99,235,.4); }
    .brd-cta-dash { background: rgba(124,58,237,.9); color: #fff; }
    .brd-cta-dash:hover { background: #7c3aed; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(124,58,237,.4); }
    .brd-cta-story { background: rgba(13,148,136,.9); color: #fff; }
    .brd-cta-story:hover { background: #0d9488; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(13,148,136,.4); }
    .brd-stats-row {
      position: relative; margin-top: 36px;
      display: flex; gap: 0;
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 12px; overflow: hidden;
      max-width: 520px;
    }
    .brd-stat {
      flex: 1; padding: 16px 20px; text-align: center;
      border-right: 1px solid rgba(255,255,255,.06);
      transition: background .2s;
    }
    .brd-stat:last-child { border-right: none; }
    .brd-stat:hover { background: rgba(255,255,255,.06); }
    .brd-stat-val { display: block; font-size: 22px; font-weight: 800; color: #fff; }
    .brd-stat-lbl { display: block; font-size: 10px; color: rgba(255,255,255,.45); margin-top: 2px; letter-spacing: .5px; }

    /* feature section */
    .brd-features { padding: 48px 48px 40px; background: var(--bg); }
    .brd-sec-title {
      font-size: 20px; font-weight: 700; color: var(--text);
      margin-bottom: 20px;
    }
    .brd-feat-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
    .brd-feat-card {
      position: relative; overflow: hidden;
      border-radius: 14px; padding: 24px;
      cursor: pointer; transition: transform .2s, box-shadow .2s;
      display: flex; flex-direction: column; gap: 8px;
    }
    .brd-feat-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(0,0,0,.15); }
    .brd-feat-blue  { background: linear-gradient(135deg,#1d4ed8,#2563eb,#3b82f6); color:#fff; }
    .brd-feat-purple{ background: linear-gradient(135deg,#5b21b6,#7c3aed,#8b5cf6); color:#fff; }
    .brd-feat-teal  { background: linear-gradient(135deg,#0f766e,#0d9488,#14b8a6); color:#fff; }
    .brd-feat-icon  { font-size: 28px; }
    .brd-feat-title { font-size: 16px; font-weight: 700; }
    .brd-feat-desc  { font-size: 11px; opacity: .8; line-height: 1.6; flex: 1; }
    .brd-feat-arrow { font-size: 18px; font-weight: 700; opacity: .6; align-self: flex-end; transition: transform .2s; }
    .brd-feat-card:hover .brd-feat-arrow { transform: translateX(4px); opacity: 1; }
    .brd-feat-card::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(ellipse 80% 60% at 80% 0%, rgba(255,255,255,.12) 0%, transparent 60%);
      pointer-events: none;
    }

