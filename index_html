// HELPERS
// ══════════════════════════════════════════════
const KELAS_COLOR = {
  "Sangat Tinggi":"#7f1d1d",
  "Tinggi":"#ef4444",
  "Sedang":"#f97316",
  "Rendah":"#3b82f6",
  "Sangat Rendah":"#1e3a8a"
};
const KELAS_BG = {
  "Sangat Tinggi":"#fef2f2",
  "Tinggi":"#fff1f2",
  "Sedang":"#fff7ed",
  "Rendah":"#eff6ff",
  "Sangat Rendah":"#eff6ff"
};

function fmt(n){ return 'Rp '+new Intl.NumberFormat('id-ID').format(n)+'/m²'; }
function fmtM(n){ return 'Rp '+(n/1000000).toFixed(1)+' Jt'; }

// ══════════════════════════════════════════════
// MAP INIT
// ══════════════════════════════════════════════
const map = L.map('map',{center:[-7.3532,112.7671],zoom:13,zoomControl:false});
L.control.zoom({position:'topright'}).addTo(map);

const TILES = {
  light: L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',{attribution:'© OSM · Esri · CartoDB',maxZoom:19}),
  osm:   L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap',maxZoom:19}),
  satellite: L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',{attribution:'© ESRI',maxZoom:19})
};
TILES.light.addTo(map);

// coord display
map.on('mousemove', e => {
  document.getElementById('coord-text').textContent =
    e.latlng.lat.toFixed(6)+'°N  '+e.latlng.lng.toFixed(6)+'°E';
});

// ══════════════════════════════════════════════
// CHOROPLETH
// ══════════════════════════════════════════════
let choroplethGrp = L.layerGroup().addTo(map);
let batasGrp      = L.layerGroup().addTo(map);
let currentOpacity = 0.7;

function buildChoropleth(filterKelas='', filterKel=''){
  choroplethGrp.clearLayers();
  batasGrp.clearLayers();
  ZONA.forEach(z=>{
    if(filterKelas && z.kelas!==filterKelas) return;
    if(filterKel   && z.kelurahan!==filterKel) return;
    const color = KELAS_COLOR[z.kelas];
    const poly = L.polygon(z.coords,{
      color:'#fff', weight:1.5, opacity:.8,
      fillColor:color, fillOpacity:currentOpacity
    });
    // batas (outline only)
    const batas = L.polygon(z.coords,{
      color:'#334155', weight:1.5, fill:false, opacity:.5, dashArray:'4 3'
    });

    const badge = `<span style="background:${KELAS_BG[z.kelas]};color:${color};padding:2px 9px;border-radius:99px;font-size:10px;font-weight:700;display:inline-block;margin-bottom:8px;">${z.kelas}</span>`;
    poly.bindPopup(`
      <div class="popup-box">
        <div class="popup-head">📍 ${z.kelurahan}</div>
        ${badge}
        <div class="popup-grid">
          <div class="popup-kv"><span class="popup-k">Nilai Rata-rata</span><span class="popup-v" style="color:${color}">${fmtM(z.nilai_rata)}</span></div>
          <div class="popup-kv"><span class="popup-k">Median</span><span class="popup-v">${fmtM(z.nilai_median)}</span></div>
          <div class="popup-kv"><span class="popup-k">Nilai Min</span><span class="popup-v">${fmtM(z.nilai_min)}</span></div>
          <div class="popup-kv"><span class="popup-k">Nilai Max</span><span class="popup-v">${fmtM(z.nilai_max)}</span></div>
          <div class="popup-kv"><span class="popup-k">Sampel</span><span class="popup-v">${z.sampel} titik</span></div>
          <div class="popup-kv"><span class="popup-k">COD</span><span class="popup-v">${z.cod}%</span></div>
        </div>
        <hr class="popup-divider">
        <div class="popup-note">Faktor dominan: <b>${z.faktor}</b></div>
      </div>`);
    choroplethGrp.addLayer(poly);
    batasGrp.addLayer(batas);
  });
}

// ══════════════════════════════════════════════
// HEATMAP
// ══════════════════════════════════════════════
let heatLayer = null;
let kdeR = 25;

function buildHeat(){
  if(heatLayer) map.removeLayer(heatLayer);
  const pts = SAMPEL.map(s=>[s.lat,s.lng,s.harga/8100000]);
  heatLayer = L.heatLayer(pts,{radius:kdeR,blur:15,maxZoom:17,
    gradient:{0:'#1e3a8a',0.25:'#3b82f6',0.5:'#f97316',0.75:'#ef4444',1:'#7f1d1d'}});
  if(document.getElementById('chk-heatmap').checked) heatLayer.addTo(map);
}

// ══════════════════════════════════════════════
// BUBBLE
// ══════════════════════════════════════════════
let bubbleGrp = L.layerGroup();

function buildBubble(filterKelas=''){
  bubbleGrp.clearLayers();
  SAMPEL.forEach(s=>{
    if(filterKelas && s.kelas!==filterKelas) return;
    const color = KELAS_COLOR[s.kelas];
    const r = 6+(s.harga/8100000)*16;
    const c = L.circleMarker([s.lat,s.lng],{
      radius:r, color:'#fff', weight:1.5, fillColor:color, fillOpacity:.75
    });
    c.bindPopup(`
      <div class="popup-box">
        <div class="popup-head">📌 ${s.nama}</div>
        <span style="background:${KELAS_BG[s.kelas]};color:${color};padding:2px 9px;border-radius:99px;font-size:10px;font-weight:700;display:inline-block;margin-bottom:8px;">${s.kelas}</span>
        <div class="popup-grid">
          <div class="popup-kv"><span class="popup-k">Harga/m²</span><span class="popup-v" style="color:${color}">${fmtM(s.harga)}</span></div>
          <div class="popup-kv"><span class="popup-k">Jarak CBD</span><span class="popup-v">${s.cbd} km</span></div>
          <div class="popup-kv"><span class="popup-k">Lat</span><span class="popup-v">${s.lat.toFixed(4)}</span></div>
          <div class="popup-kv"><span class="popup-k">Lng</span><span class="popup-v">${s.lng.toFixed(4)}</span></div>
        </div>
      </div>`);
    bubbleGrp.addLayer(c);
  });
  if(document.getElementById('chk-bubble').checked) bubbleGrp.addTo(map);
}

// ══════════════════════════════════════════════
// FASILITAS
// ══════════════════════════════════════════════
let fasGrp = L.layerGroup();
let bufferRadius = 500;
let bufferCircle = null;

function buildFas(){
  fasGrp.clearLayers();
  const active = [...document.querySelectorAll('.fas-chk:checked')].map(el=>el.dataset.cat);
  FASILITAS.forEach(f=>{
    if(!active.includes(f.kat)) return;
    const icon = L.divIcon({
      html:`<div style="font-size:20px;filter:drop-shadow(0 1px 3px rgba(0,0,0,.5));line-height:1;">${f.icon}</div>`,
      iconSize:[24,24],iconAnchor:[12,12],className:''
    });
    const m = L.marker([f.lat,f.lng],{icon});
    m.on('click',()=>{
      if(bufferCircle) map.removeLayer(bufferCircle);
      bufferCircle = L.circle([f.lat,f.lng],{
        radius:bufferRadius, color:'#2563eb', fillColor:'#2563eb',
        fillOpacity:.08, weight:1.5, dashArray:'6 4'
      }).addTo(map);
    });
    m.bindPopup(`
      <div class="popup-box">
        <div class="popup-head">${f.icon} ${f.nama}</div>
        <div class="popup-note" style="margin-top:4px;">Kategori: <b>${f.kat}</b></div>
        <div class="popup-note">Lat: ${f.lat.toFixed(6)} · Lng: ${f.lng.toFixed(6)}</div>
        <div class="popup-note" style="margin-top:6px;color:var(--blue);">🔵 Klik untuk tampilkan buffer ${bufferRadius}m</div>
      </div>`);
    fasGrp.addLayer(m);
  });
}

// ── JALAN ──────────────────────────────────────────────────
let jalanGrp = L.layerGroup();

function buildJalan(){
  jalanGrp.clearLayers();
  JALAN.forEach(j=>{
    const line = L.polyline(j.coords.map(c=>[c[1],c[0]]),{
      color: j.warna,
      weight: j.lebar,
      opacity: 0.75
    });
    line.bindPopup(`
      <div class="popup-box">
        <div class="popup-head">🛣️ ${j.nama || j.jenis}</div>
        <div class="popup-note">Jenis: <b style="text-transform:capitalize">${j.jenis}</b></div>
      </div>`);
    jalanGrp.addLayer(line);
  });
  if(document.getElementById('chk-jalan') && document.getElementById('chk-jalan').checked){
    jalanGrp.addTo(map);
  }
}

// ══════════════════════════════════════════════
// CONTROLS
// ══════════════════════════════════════════════
function toggleLayer(name){
  if(name==='choropleth'){
    document.getElementById('chk-choropleth').checked ? choroplethGrp.addTo(map) : map.removeLayer(choroplethGrp);
  } else if(name==='batas'){
    document.getElementById('chk-batas').checked ? batasGrp.addTo(map) : map.removeLayer(batasGrp);
  } else if(name==='bubble'){
    document.getElementById('chk-bubble').checked ? bubbleGrp.addTo(map) : map.removeLayer(bubbleGrp);
  } else if(name==='heatmap'){
    if(document.getElementById('chk-heatmap').checked){ if(heatLayer) heatLayer.addTo(map); }
    else { if(heatLayer) map.removeLayer(heatLayer); }
  } else if(name==='jalan'){
    document.getElementById('chk-jalan').checked ? jalanGrp.addTo(map) : map.removeLayer(jalanGrp);
  }
}

function setOpacity(v){
  currentOpacity = v/100;
  document.getElementById('val-opacity').textContent = v+'%';
  choroplethGrp.eachLayer(l=>l.setStyle({fillOpacity:currentOpacity}));
}

function setKDE(v){
  kdeR = parseInt(v);
  document.getElementById('val-kde').textContent = v;
  buildHeat();
}

function filterFas(){ buildFas(); }

function setBufferRadius(v){ bufferRadius = parseInt(v); if(bufferCircle) map.removeLayer(bufferCircle); }

function setBasemap(k){
  Object.values(TILES).forEach(t=>map.removeLayer(t));
  TILES[k].addTo(map);
}

function applyFilter(){
  const k = document.getElementById('filter-kelas').value;
  const kel = document.getElementById('filter-kel').value;
  buildChoropleth(k,kel);
  buildBubble(k);
  if(kel){
    const z = ZONA.find(z=>z.kelurahan===kel);
    if(z){ const c=z.coords; map.flyTo([-7.3532,112.7671],13,{duration:1}); }
  }
}

function searchZone(){
  const q = document.getElementById('search-bar').value.toLowerCase().trim();
  if(!q) return;
  const z = ZONA.find(z=>z.kelurahan.toLowerCase().includes(q));
  if(z){ const c=z.coords; map.flyTo([-7.3532,112.7671],13,{duration:1.2}); }
}

function resetFilter(){
  document.getElementById('filter-kelas').value='';
  document.getElementById('filter-kel').value='';
  document.getElementById('search-bar').value='';
  buildChoropleth(); buildBubble();
  map.flyTo([-7.3532,112.7671],13,{duration:1});
}

// panel tabs
function setTab(name, el){
  document.querySelectorAll('.ptab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  ['lapisan','overlay','legenda'].forEach(id=>{
    document.getElementById('tab-'+id).style.display = id===name ? 'block' : 'none';
  });
}

// ══════════════════════════════════════════════
// VIEW SWITCHER
// ══════════════════════════════════════════════
function switchView(v){
  const views = {map:'map-view', dash:'dash-view', story:'story-view', beranda:'beranda-view'};
  Object.entries(views).forEach(([key,id])=>{
    const el = document.getElementById(id);
    if(!el) return;
    if(key==='map'){
      el.style.display = key===v ? 'flex' : 'none';
    } else {
      el.style.display = key===v ? 'block' : 'none';
    }
  });
  document.querySelectorAll('.nav-link').forEach(btn=>btn.classList.remove('active'));
  const idx = ['beranda','story','dash','map'].indexOf(v);
  if(idx>=0) document.querySelectorAll('.nav-link')[idx].classList.add('active');
  if(v==='map') setTimeout(()=>map.invalidateSize(),60);
}

// ══════════════════════════════════════════════
// DASHBOARD CHARTS
// ══════════════════════════════════════════════
function buildBarChart(){
  const sorted = [...ZONA].sort((a,b)=>b.nilai_rata-a.nilai_rata);
  const max = sorted[0].nilai_rata;
  document.getElementById('bar-chart').innerHTML = sorted.map(z=>`
    <div class="bar-row">
      <div class="bar-label">${z.kelurahan}</div>
      <div class="bar-track">
        <div class="bar-fill" style="width:${(z.nilai_rata/max*100).toFixed(1)}%;background:${KELAS_COLOR[z.kelas]}">
          <span class="bar-text">${fmtM(z.nilai_rata)}</span>
        </div>
      </div>
    </div>`).join('');
}

function buildHistogram(){
  const bins=[
    {label:'< 2,5 Jt',min:0,max:2500000},
    {label:'2,5–3,5 Jt',min:2500000,max:3500000},
    {label:'3,5–4,5 Jt',min:3500000,max:4500000},
    {label:'4,5–5,5 Jt',min:4500000,max:5500000},
    {label:'5,5–6,5 Jt',min:5500000,max:6500000},
    {label:'6,5–8,5 Jt',min:6500000,max:9000000}
  ];
  const counts = bins.map(b=>SAMPEL.filter(s=>s.harga>=b.min&&s.harga<b.max).length);
  const mx = Math.max(...counts);
  document.getElementById('histogram').innerHTML = bins.map((b,i)=>`
    <div class="hist-row">
      <div class="hist-label">${b.label}</div>
      <div class="hist-track">
        <div class="hist-fill" style="width:${(counts[i]/mx*100).toFixed(1)}%;background:#2563eb">
          <span class="hist-count">${counts[i]}</span>
        </div>
      </div>
    </div>`).join('');
}

function buildScatter(){
  const W=500,H=200,px=40,py=20;
  const n=SAMPEL.length;
  const mx2=SAMPEL.reduce((a,s)=>a+s.cbd,0)/n;
  const my2=SAMPEL.reduce((a,s)=>a+s.harga,0)/n;
  const num=SAMPEL.reduce((a,s)=>a+(s.cbd-mx2)*(s.harga-my2),0);
  const den=SAMPEL.reduce((a,s)=>a+(s.cbd-mx2)**2,0);
  const slope=num/den, intercept=my2-slope*mx2;
  const maxX=8,maxY=9000000;
  const sx=v=>px+(v/maxX)*(W-px*2);
  const sy=v=>H-py-(v/maxY)*(H-py*2);
  const pts=SAMPEL.map(s=>`
    <circle cx="${sx(s.cbd).toFixed(1)}" cy="${sy(s.harga).toFixed(1)}" r="5"
      fill="${KELAS_COLOR[s.kelas]}" stroke="#fff" stroke-width="1.5" opacity=".85">
      <title>${s.nama}: ${fmtM(s.harga)}</title>
    </circle>`).join('');
  document.getElementById('scatter').innerHTML = `
    <svg viewBox="0 0 ${W} ${H}" class="scatter-svg" xmlns="http://www.w3.org/2000/svg">
      ${[0,2,4,6,8].map(x=>`
        <line x1="${sx(x)}" y1="${py}" x2="${sx(x)}" y2="${H-py}" stroke="#e2e5ec" stroke-width="1"/>
        <text x="${sx(x)}" y="${H-4}" text-anchor="middle" font-size="9" fill="#718096" font-family="Inter,sans-serif">${x}km</text>`).join('')}
      ${[0,3,6,9].map(y=>`
        <line x1="${px}" y1="${sy(y*1e6)}" x2="${W-px}" y2="${sy(y*1e6)}" stroke="#e2e5ec" stroke-width="1"/>
        <text x="${px-4}" y="${sy(y*1e6)+3}" text-anchor="end" font-size="9" fill="#718096" font-family="Inter,sans-serif">${y}Jt</text>`).join('')}
      <line x1="${sx(0)}" y1="${sy(intercept)}" x2="${sx(maxX)}" y2="${sy(slope*maxX+intercept)}"
        stroke="#2563eb" stroke-width="1.5" stroke-dasharray="5 3" opacity=".6"/>
      ${pts}
      <text x="${W/2}" y="${H}" text-anchor="middle" font-size="9" fill="#718096" font-family="Inter,sans-serif">Jarak ke CBD (km)</text>
    </svg>`;
}

function buildBoxPlot(){
  const groups=['Sangat Rendah','Rendah','Sedang','Tinggi','Sangat Tinggi'];
  const BW=140,BH=190,pad=22;
  const globalMin=1800000,globalMax=8500000;
  const sc=v=>BH-pad-(v-globalMin)/(globalMax-globalMin)*(BH-pad*2);
  document.getElementById('boxplot').innerHTML = groups.map(kelas=>{
    const vals=SAMPEL.filter(s=>s.kelas===kelas).map(s=>s.harga).sort((a,b)=>a-b);
    const q1=vals[Math.floor(vals.length*.25)];
    const med=vals[Math.floor(vals.length*.5)];
    const q3=vals[Math.floor(vals.length*.75)];
    const mn=vals[0],mx=vals[vals.length-1];
    const color=KELAS_COLOR[kelas];
    return `<svg viewBox="0 0 ${BW} ${BH}" width="${BW}" height="${BH}" style="flex-shrink:0">
      <line x1="${BW/2}" y1="${sc(mn)}" x2="${BW/2}" y2="${sc(q3)}" stroke="${color}" stroke-width="1.5" stroke-dasharray="4 3"/>
      <line x1="${BW/2}" y1="${sc(q1)}" x2="${BW/2}" y2="${sc(mx)}" stroke="${color}" stroke-width="1.5" stroke-dasharray="4 3"/>
      <rect x="${BW/2-22}" y="${sc(q3)}" width="44" height="${sc(q1)-sc(q3)}"
        fill="${KELAS_BG[kelas]}" stroke="${color}" stroke-width="1.5" rx="3"/>
      <line x1="${BW/2-22}" y1="${sc(med)}" x2="${BW/2+22}" y2="${sc(med)}" stroke="${color}" stroke-width="2.5"/>
      <text x="${BW/2}" y="${BH-4}" text-anchor="middle" font-size="11" fill="${color}"
        font-family="Inter,sans-serif" font-weight="700">${kelas}</text>
      <text x="${BW/2+26}" y="${sc(med)+3}" font-size="9" fill="#718096" font-family="Inter,sans-serif">${fmtM(med)}</text>
    </svg>`;
  }).join('');
}

function buildTable(){
  document.getElementById('tbl-body').innerHTML = [...ZONA].sort((a,b)=>b.nilai_rata-a.nilai_rata).map(z=>{
    const c=KELAS_COLOR[z.kelas], bg=KELAS_BG[z.kelas];
    return `<tr>
      <td>${z.kelurahan}</td>
      <td><span class="badge" style="background:${bg};color:${c}">${z.kelas}</span></td>
      <td style="font-variant-numeric:tabular-nums">${fmtM(z.nilai_min)}</td>
      <td style="font-variant-numeric:tabular-nums">${fmtM(z.nilai_max)}</td>
      <td style="font-variant-numeric:tabular-nums;font-weight:600;color:${c}">${fmtM(z.nilai_rata)}</td>
      <td style="font-variant-numeric:tabular-nums">${fmtM(z.nilai_median)}</td>
      <td>${z.sampel}</td>
      <td>${z.cod}%</td>
    </tr>`;
  }).join('');
}

function exportCSV(){
  const h='Kelurahan,Kelas ZNT,Nilai Min,Nilai Max,Nilai Rata-rata,Median,Sampel,COD\n';
  const r=ZONA.map(z=>`${z.kelurahan},${z.kelas},${z.nilai_min},${z.nilai_max},${z.nilai_rata},${z.nilai_median},${z.sampel},${z.cod}`).join('\n');
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([h+r],{type:'text/csv'}));
  a.download='ZNT_Waru_2026.csv'; a.click();
}

